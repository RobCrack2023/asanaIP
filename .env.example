# ── AsanaIP – Plantilla de configuración ─────────────────────────────────────
# Copiá este archivo como ".env" y completá los valores.
#   cp .env.example .env

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# URL base del frontend (sin barra final)
APP_URL=https://tudominio.com

# ── Email ─────────────────────────────────────────────────────────────────────
# Desarrollo: usa "django.core.mail.backends.console.EmailBackend"
# Producción: usa "django.core.mail.backends.smtp.EmailBackend"
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=AsanaIP <noreply@tudominio.com>

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-de-gmail
